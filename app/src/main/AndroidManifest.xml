<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <application
        android:name=".ShiftCal"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="${usesCleartextTraffic}">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.editor.ShiftBlocksActivity"
            android:exported="false" />
        <activity
            android:name=".ui.editor.ShiftBlockCreatorActivity"
            android:exported="false" />
        <activity
            android:name=".ui.settings.AdvancedSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.settings.export.ExportActivity"
            android:exported="false" />
        <activity
            android:name=".ui.settings.AboutActivity"
            android:exported="false" />

        <activity
            android:name=".ui.editor.ShiftCreatorActivity"
            android:label="@string/shift_creator_title" />
        <activity
            android:name=".ui.editor.ShiftsActivity"
            android:label="@string/shifts_title" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_pdf_paths" />
        </provider>
    </application>

</manifest>
