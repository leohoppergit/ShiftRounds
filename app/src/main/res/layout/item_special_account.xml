<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:background="@drawable/shift_rounds_settings_inline_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <View
        android:id="@+id/specialAccountColorDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/shift_rounds_special_date_dot"
        android:backgroundTint="@color/shiftRoundsSelection" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/specialAccountNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/specialAccountMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/settings_special_accounts_item_meta"
            android:textSize="13sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/editSpecialAccountButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/special_account_edit"
        android:padding="8dp"
        android:src="@drawable/ic_edit" />

    <ImageButton
        android:id="@+id/deleteSpecialAccountButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/special_account_delete"
        android:padding="8dp"
        android:src="@drawable/ic_delete" />

</LinearLayout>
