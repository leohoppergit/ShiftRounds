<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:importantForAutofill="noExcludeDescendants"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <EditText
        android:id="@+id/workDayNoteEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top|start"
        android:hint="@string/note_hint"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="3" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/work_day_details_overtime_title" />

    <RadioGroup
        android:id="@+id/workDayTimeTypeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/workDayOvertimeOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_time_overtime_label" />

        <RadioButton
            android:id="@+id/workDayLessWorkOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/stats_time_less_work_label" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/workDayOvertimeHoursEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="4"
            android:hint="@string/work_day_details_hours_hint"
            android:inputType="number" />

        <EditText
            android:id="@+id/workDayOvertimeMinutesEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ems="4"
            android:hint="@string/work_day_details_minutes_hint"
            android:inputType="number" />
    </LinearLayout>

    <TextView
        android:id="@+id/workDayMultiplierInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:alpha="0.85"
        android:visibility="gone" />

    <TextView
        android:id="@+id/workDayMultiplierPreviewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
