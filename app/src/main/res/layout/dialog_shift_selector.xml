<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="6dp">

    <ListView
        android:id="@+id/shift_selector_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="4dp"
        android:divider="@color/transparent"
        android:dividerHeight="0dp" />

    <LinearLayout
        android:id="@+id/shift_selector_special_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shift_selector_delete_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="54dp"
            android:text="@string/shift_list_delete_calendar_entry"
            android:textAllCaps="false"
            android:textColor="@color/shiftRoundsTitleInk"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconTint="@color/shiftRoundsTitleInk"
            app:strokeColor="@color/shiftRoundsPanelStroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shift_selector_create_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="54dp"
            android:text="@string/shift_list_create_new_shift"
            android:textAllCaps="false"
            android:textColor="@color/shiftRoundsTitleInk"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="@color/shiftRoundsTitleInk"
            app:strokeColor="@color/shiftRoundsPanelStroke" />

    </LinearLayout>

</LinearLayout>
