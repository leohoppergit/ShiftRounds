<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.stats.StatsFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/statsContent"
        android:layout_height="match_parent"
        android:layout_width="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statsFromText"
                style="@style/Text.SectionTitle"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/stats_from" />

            <TextView
                style="@style/Text.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/stats_time_tile" />

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                app:columnCount="2">

                <TextView
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsMutedInk"
                    android:textSize="18sp"
                    android:text="@string/stats_time_work_label" />

                <TextView
                    android:id="@+id/statsWorkTimeText"
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsTitleInk"
                    android:textAlignment="textEnd"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsMutedInk"
                    android:textSize="18sp"
                    android:text="@string/stats_time_break_label" />

                <TextView
                    android:id="@+id/statsBreakTimeText"
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsTitleInk"
                    android:textAlignment="textEnd"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statsOvertimeLabel"
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsMutedInk"
                    android:textSize="18sp"
                    android:text="@string/stats_time_overtime_label" />

                <TextView
                    android:id="@+id/statsOvertimeText"
                    android:layout_width="0dp"
                    app:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="4dp"
                    android:textColor="@color/shiftRoundsTitleInk"
                    android:textAlignment="textEnd"
                    android:textSize="19sp"
                    android:textStyle="bold" />

            </androidx.gridlayout.widget.GridLayout>


            <TextView
                style="@style/Text.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:text="@string/stats_shifts_tile" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listViewShifts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                style="@style/Text.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:text="@string/stats_weekdays_title" />

            <LinearLayout
                android:id="@+id/statsWeekDaysContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/mondayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/tuesdayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/wednesdayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/thursdayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/fridayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/saturdayStat"
                    layout="@layout/item_week_day_stat" />

                <include
                    android:id="@+id/sundayStat"
                    layout="@layout/item_week_day_stat" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/specialAccountsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Text.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/stats_special_accounts_title" />

                <LinearLayout
                    android:id="@+id/specialAccountsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/emptyStatsContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:drawablePadding="20dp"
        android:gravity="center"
        android:padding="32dp"
        android:text="@string/stats_empty_text"
        android:textAlignment="center"
        app:drawableTopCompat="@drawable/ic_owl_watermark"
        android:textAppearance="@style/Text.SectionTitle" />

</FrameLayout>
