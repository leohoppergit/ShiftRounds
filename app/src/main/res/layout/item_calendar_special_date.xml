<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <View
        android:id="@+id/specialDateDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/shift_rounds_special_date_dot" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/specialDateNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/shiftRoundsTitleInk"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/specialDateTypeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/shiftRoundsMutedInk"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/specialDateRangeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/shiftRoundsMutedInk"
        android:textSize="12sp" />

</LinearLayout>
