<?xml version="1.0" encoding="utf-8"?>
<de.nulide.shiftcal.ui.helper.ExpandableLinearLayout.ExpandableLinearLayout android:id="@+id/monthNoteBox"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:visibility="gone"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/shift_rounds_calendar_panel"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:id="@+id/monthNoteText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/shiftRoundsTitleInk"
        android:textSize="15sp"
        android:textAlignment="center" />

</de.nulide.shiftcal.ui.helper.ExpandableLinearLayout.ExpandableLinearLayout>
